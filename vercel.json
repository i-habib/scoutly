{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/zohoverify/verifyforzoho.html",
      "dest": "/zohoverify/verifyforzoho.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "assets/$1"
    },
    {
      "src": "/(favicon\\.ico|.*\\.png|.*\\.svg|.*\\.json|robots\\.txt)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ]
}
