{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "assets/$1"
    },
    {
      "src": "/(favicon\\.ico|.*\\.png|.*\\.svg|.*\\.json|robots\\.txt|zohoverify/.*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ]
}

